rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/clients
    // Document ID: Auto-generated
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - address: string (required, max 200 chars)
    //   - phone: string (required, max 20 chars)
    //   - email: string (required, max 100 chars)
    //   - lat: number (required)
    //   - lng: number (required)
    //   - history: list (required)
    //   - equipment: list (required)
    //   - notes: list (required)
    //
    // Collection: users/{userId}/notifications
    // Document ID: Auto-generated
    // Fields:
    //   - title: string (required, max 100 chars)
    //   - message: string (required, max 500 chars)
    //   - type: string (required, in ['maintenance', 'pending_call', 'system'])
    //   - date: string (required, max 50 chars)
    //   - read: boolean (required)
    //   - clientId: string (optional, max 50 chars)
    //
    // Collection: users/{userId}/settings
    // Document ID: 'appSettings'
    // Fields:
    //   - defaultMaintenanceInterval: number (required, > 0)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "amigorefrigerista@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidClient() {
      return hasRequiredFields(['name', 'address', 'phone', 'email', 'lat', 'lng', 'history', 'equipment', 'notes']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('address', 1, 200) &&
             validStringLength('phone', 1, 20) &&
             validStringLength('email', 0, 100) &&
             request.resource.data.lat is number &&
             request.resource.data.lng is number &&
             request.resource.data.history is list &&
             request.resource.data.equipment is list &&
             request.resource.data.notes is list;
    }

    function isValidNotification() {
      return hasRequiredFields(['title', 'message', 'type', 'date', 'read']) &&
             validStringLength('title', 1, 100) &&
             validStringLength('message', 1, 500) &&
             request.resource.data.type in ['maintenance', 'pending_call', 'system'] &&
             validStringLength('date', 1, 50) &&
             request.resource.data.read is bool &&
             isValidOptionalString('clientId', 1, 50);
    }

    function isValidSettings() {
      return hasRequiredFields(['defaultMaintenanceInterval']) &&
             request.resource.data.defaultMaintenanceInterval is number &&
             request.resource.data.defaultMaintenanceInterval > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /clients/{clientId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidClient();
        allow update: if isOwner(userId) && isValidClient();
        allow delete: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNotification();
        allow update: if isOwner(userId) && isValidNotification();
        allow delete: if isOwner(userId);
      }

      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSettings();
        allow update: if isOwner(userId) && isValidSettings();
        allow delete: if isOwner(userId);
      }
    }
  }
}